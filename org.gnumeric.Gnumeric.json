{
    "id": "org.gnumeric.Gnumeric",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "gnumeric",
    "rename-icon": "org.gnumeric.gnumeric",
    "copy-icon": true,
    "rename-desktop-file": "org.gnumeric.gnumeric.desktop",
    "rename-appdata-file": "org.gnumeric.gnumeric.appdata.xml",
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--filesystem=home",
        "--talk-name=org.gtk.vfs.*",
        "--filesystem=xdg-run/gvfs",
        "--filesystem=xdg-run/gvfsd"
    ],
    "modules": [
        "shared-modules/intltool/intltool-0.51.json",
        {
            "name": "gsf",
            "config-opts": [
                "--disable-static"
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig",
                "/share/man",
                "/share/gtk-doc/html/gsf",
                "/share/thumbnailers",
                "/bin/gsf*",
                "*.la"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/libgsf/1.14/libgsf-1.14.57.tar.xz",
                    "sha256": "3bf1892bf2c41c8877fdb20d3e9a91b1f09ed5c65b0de609ff374f4caa195bd3",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "libgsf",
                        "versions": {
                            "<": "1.15"
                        },
                        "stable-only": true
                    }
                }
            ]
        },
        {
            "name": "goffice",
            "config-opts": [
                "--disable-static"
            ],
            "cleanup": [
                "/include",
                "/share/gtk-doc",
                "/lib/pkgconfig",
                "*.la"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/goffice/0.10/goffice-0.10.61.tar.xz",
                    "sha256": "558597fd9ca59b93ff562750218d1e7ea8ec3c8d0ed6a5cc096aa715ef909a15",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "goffice",
                        "versions": {
                            "<": "0.11"
                        },
                        "stable-only": true
                    }
                }
            ]
        },
        {
            "name": "psiconv",
            "config-opts": [
                "--disable-static"
            ],
            "cleanup": [
                "/include",
                "/share/man",
                "/share/psiconv",
                "/bin/psiconv*",
                "*.la"
            ],
            "build-options": {
                "cflags": "-fcommon"
            },
            "sources": [
                {
                    "type": "archive",
                    "url": "http://www.frodo.looijaard.name/system/files/software/psiconv/psiconv-0.9.9.tar.gz",
                    "sha256": "6d51fe79b502a1e277bea275a574ae2db5b1b9d7daef703a8fa3635ae02a8bb0"
                },
                {
                    "type": "patch",
                    "path": "patches/psiconv-fixes.patch"
                },
                {
                    "type": "shell",
                    "commands": [
                        "autoreconf -vfi"
                    ]
                }
            ]
        },
        {
            "name": "pxlib",
            "build-options": {
                "cflags": "-fpermissive"
            },
            "config-opts": [
                "--disable-static"
            ],
            "cleanup": [
                "/include",
                "*.la"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.sourceforge.net/project/pxlib/pxlib/0.6.8/pxlib-0.6.8.tar.gz",
                    "sha256": "5f9b58a5c3d9e5e60faad16dfbc5172ee14ae57a978732378660c0f2c9e74ef9"
                }
            ]
        },
        {
            "name": "gnumeric",
            "buildsystem": "autotools",
            "cleanup": [
                "/include"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/gnumeric/1.12/gnumeric-1.12.61.tar.xz",
                    "sha256": "2ac135d856572713c1a408b76b50a59f2a9769ed21f1213446b5af255df20a12",
                    "x-checker-data": {
                        "type": "gnome",
                        "name": "gnumeric",
                        "stable-only": true
                    }
                },
                {
                    "type": "patch",
                    "paths": [
                        "patches/gnumerica-appstream.patch",
                        "patches/gnumeric-aislop-fixed.patch"
                    ]
                }
            ]
        }
    ]
}
